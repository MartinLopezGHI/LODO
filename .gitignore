# --- Dependencias y Paquetes ---
node_modules/
frontend/node_modules/
backend/vendor/
cargadb/venv/
.venv/
package-lock.json
yarn.lock

# --- Secretos y Configuración (¡CRÍTICO!) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
cargadb/.env
# Credenciales de Google Cloud
cargadb/service_account.json
github-key.json
# Datos locales de Docker Compose (Base de datos)
lodo_db_data/

# --- Salidas de Compilación (Build) ---
frontend/dist/
# Binarios de Go (Windows y Linux)
backend/*.exe
backend/main
*.exe
bin/
# Python cache
__pycache__/
*.py[cod]
*$py.class

# --- IDEs y Sistema Operativo ---
.idea/
.vscode/
.cursor/
.cursorignore
*.swp
*.tmp
.DS_Store
Thumbs.db

# --- Logs y Debugging ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Datos y Análisis (Específico LODO) ---
# No subir archivos de Excel o CSV sucios o procesados
cargadb/excels/1_sucios/*
cargadb/excels/2_limpios/*
cargadb/excels/3_usados/*
cargadb/config/*
analysis_scripts/

# Permitir que Git rastree las carpetas aunque estén vacías usando .gitkeep
!cargadb/excels/1_sucios/.gitkeep
!cargadb/excels/2_limpios/.gitkeep
!cargadb/config/.gitkeep

# --- Docker ---
.docker/